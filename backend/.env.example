# Backend environment variables
# Copy this file to .env for local development

# --- AI ---
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Django ---
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=true
# Comma-separated list of additional allowed hosts (localhost/127.0.0.1 always included)
# DJANGO_ALLOWED_HOSTS=yourdomain.com

# --- Database ---
# Set DATABASE_URL for any hosted PostgreSQL (Render sets this automatically).
# Alternatively, use individual POSTGRES_* vars for local Docker setup.
# DATABASE_URL=postgres://user:password@host:5432/dbname
# POSTGRES_DB=engage_pilot
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# --- CORS ---
# Set to your deployed Vercel frontend URL
# FRONTEND_URL=https://your-app.vercel.app
# Set to "true" to allow all origins (useful for development/staging)
# CORS_ALLOW_ALL=false
