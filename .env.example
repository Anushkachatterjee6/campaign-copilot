# Frontend environment variables
# Copy this file to .env.local for local development overrides

# Base URL of the deployed Django backend (no trailing slash)
# Leave unset locally — the app will fall back to http://127.0.0.1:8000
VITE_API_BASE_URL=https://your-backend.onrender.com

# WebSocket base URL (optional — derived from VITE_API_BASE_URL if not set)
# VITE_WS_BASE_URL=wss://your-backend.onrender.com
