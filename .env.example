# Frontend environment variables
# Copy this file to .env.local for local development overrides

# Base URL of the deployed Django backend (no trailing slash)
# Set at BUILD time on Vercel — baked into the client bundle
VITE_API_BASE_URL=https://YOUR_USERNAME-campaign-copilot-api.hf.space

# Runtime fallback injected during SSR (Vercel → Settings → Environment Variables)
# Use the same URL as VITE_API_BASE_URL so production works even if build env was missing
API_BASE_URL=https://YOUR_USERNAME-campaign-copilot-api.hf.space

# WebSocket base URL (optional — derived from VITE_API_BASE_URL if not set)
# VITE_WS_BASE_URL=wss://YOUR_USERNAME-campaign-copilot-api.hf.space
